# Glamora Backend — Environment Configuration
# Copy this to .env and fill in your values

# App
APP_NAME=Glamora
APP_URL=http://localhost:3000
ENVIRONMENT=development
DEBUG=true

# Database (PostgreSQL 16+)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/glamora
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/glamora

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET_KEY=generate-a-random-64-char-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
CORS_ORIGINS=["http://localhost:3000"]
